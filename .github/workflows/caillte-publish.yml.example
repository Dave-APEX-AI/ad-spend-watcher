# CaillteAI auto-publisher — rename to caillte-publish.yml to activate.
# Posts a queued job to Instagram (+ FB Page) via social/publish/ig_publish.py.
#
# Setup:
#   1. Repo → Settings → Secrets and variables → Actions → add:
#        IG_USER_ID, IG_ACCESS_TOKEN, FB_PAGE_ID, FB_PAGE_TOKEN, PUBLIC_BASE_URL
#   2. Commit the post's PNGs to social/publish/queue/<name>/ (so they're public on Pages)
#      and a job file, e.g. social/publish/queue/today.json.
#   3. Run manually first (Actions tab → Run workflow) before trusting the schedule.

name: caillte-publish

on:
  workflow_dispatch:
    inputs:
      job:
        description: "Path to the job JSON to publish"
        required: true
        default: "social/publish/queue/today.json"
      dry_run:
        description: "Dry run (no live post)?"
        type: boolean
        default: true
  # Uncomment to auto-post on a schedule (UTC). Example: 09:00 Mon–Fri.
  # schedule:
  #   - cron: "0 9 * * 1-5"

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Publish
        env:
          IG_USER_ID:     ${{ secrets.IG_USER_ID }}
          IG_ACCESS_TOKEN: ${{ secrets.IG_ACCESS_TOKEN }}
          FB_PAGE_ID:     ${{ secrets.FB_PAGE_ID }}
          FB_PAGE_TOKEN:  ${{ secrets.FB_PAGE_TOKEN }}
          PUBLIC_BASE_URL: ${{ secrets.PUBLIC_BASE_URL }}
        run: |
          JOB="${{ github.event.inputs.job || 'social/publish/queue/today.json' }}"
          if [ "${{ github.event.inputs.dry_run }}" = "false" ]; then
            python3 social/publish/ig_publish.py "$JOB"
          else
            python3 social/publish/ig_publish.py "$JOB" --dry-run
          fi
