# Copy to social/publish/.env and fill in. NEVER commit the real .env (it's gitignored).
# Load before running:  set -a; source social/publish/.env; set +a

# ── Instagram (required) ─────────────────────────────────────────────────────
# IG must be a BUSINESS account linked to a Facebook Page.
# Get the IG user id + a long-lived token from the Meta Graph API Explorer with
# permissions: instagram_basic, instagram_content_publish, pages_show_list,
# pages_read_engagement (+ pages_manage_posts for FB cross-post).
IG_USER_ID=
IG_ACCESS_TOKEN=

# ── Facebook Page cross-post (optional) ──────────────────────────────────────
FB_PAGE_ID=
# Page token with pages_manage_posts. If blank, the IG token is reused.
FB_PAGE_TOKEN=

# ── Public asset hosting ─────────────────────────────────────────────────────
# Where committed PNGs are served (the Graph API fetches media by URL).
# e.g. your GitHub Pages base. Used by --from-dir to build slide URLs.
PUBLIC_BASE_URL=https://dave-apex-ai.github.io/ad-spend-watcher

# ── Optional ─────────────────────────────────────────────────────────────────
# Bump if Meta deprecates the version.
GRAPH_API_VERSION=v21.0
